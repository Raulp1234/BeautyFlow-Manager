@model BeautyFlow_Manager.Controllers.TrabajadorIndependienteViewModel
@{
    ViewData["Title"] = "Crear Perfil de Trabajador Independiente";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0 text-center"><i class="bi bi-person-badge"></i> @ViewData["Title"]</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle"></i> 
                        Completa el formulario para registrarte como trabajador independiente. Podrás ofrecer tus servicios y gestionar tus propias citas.
                    </div>
                    
                    <form asp-action="CrearPerfilTrabajador" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        
                        <h5 class="text-success mb-3">Información Personal</h5>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="NombreCompleto" class="form-label"></label>
                                <input asp-for="NombreCompleto" class="form-control" placeholder="Tu nombre completo" />
                                <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DocumentoIdentidad" class="form-label"></label>
                                <input asp-for="DocumentoIdentidad" class="form-control" placeholder="DNI, CE u otro documento" />
                                <span asp-validation-for="DocumentoIdentidad" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="EspecialidadPrincipal" class="form-label"></label>
                                <input asp-for="EspecialidadPrincipal" class="form-control" placeholder="Ej: Estilista, Manicurista, Maquilladora" />
                                <span asp-validation-for="EspecialidadPrincipal" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="OtrasEspecialidades" class="form-label"></label>
                                <input asp-for="OtrasEspecialidades" class="form-control" placeholder="Otras especialidades (opcional)" />
                                <span asp-validation-for="OtrasEspecialidades" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Telefono" class="form-label"></label>
                                <input asp-for="Telefono" class="form-control" placeholder="Ej: +51 987 654 321" />
                                <span asp-validation-for="Telefono" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EmailProfesional" class="form-label"></label>
                                <input asp-for="EmailProfesional" class="form-control" placeholder="Email profesional (opcional)" />
                                <span asp-validation-for="EmailProfesional" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="AniosExperiencia" class="form-label"></label>
                                <input asp-for="AniosExperiencia" type="number" min="0" max="50" class="form-control" placeholder="Años de experiencia" />
                                <span asp-validation-for="AniosExperiencia" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PrecioReferencial" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="PrecioReferencial" type="number" step="0.01" min="0" class="form-control" placeholder="Precio promedio de servicio" />
                                </div>
                                <span asp-validation-for="PrecioReferencial" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label"></label>
                            <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Cuéntanos sobre tu experiencia, habilidades y lo que te hace único..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>
                        
                        <hr class="my-4">
                        
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary me-md-2">
                                <i class="bi bi-x-circle"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Registrar Perfil
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
