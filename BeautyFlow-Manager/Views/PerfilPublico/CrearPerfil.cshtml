@model BeautyFlow_Manager.Controllers.PerfilPublicoViewModel
@{
    ViewData["Title"] = "Trabaja con Nosotros";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0 text-center">@ViewData["Title"]</h3>
                </div>
                <div class="card-body">
                    <p class="lead text-center mb-4">
                        ¿Eres dueño de un salón de belleza o trabajador independiente? 
                        <br/>Únete a nuestra plataforma y haz crecer tu negocio.
                    </p>

                    <form asp-action="CrearPerfil" method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <div class="card h-100 border-primary">
                                    <div class="card-header bg-primary text-white text-center">
                                        <i class="bi bi-shop display-4"></i>
                                    </div>
                                    <div class="card-body text-center">
                                        <h5 class="card-title">Dueño de Salón de Belleza</h5>
                                        <p class="card-text">
                                            Registra tu salón y gestiona múltiples trabajadores, 
                                            servicios y citas en un solo lugar.
                                        </p>
                                        <div class="form-check d-flex justify-content-center">
                                            <input class="form-check-input" type="radio" 
                                                   name="TipoPerfil" id="tipoSalon" 
                                                   value="Salon" checked>
                                            <label class="form-check-label ms-2" for="tipoSalon">
                                                Seleccionar esta opción
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6 mb-4">
                                <div class="card h-100 border-success">
                                    <div class="card-header bg-success text-white text-center">
                                        <i class="bi bi-person-badge display-4"></i>
                                    </div>
                                    <div class="card-body text-center">
                                        <h5 class="card-title">Trabajador Independiente</h5>
                                        <p class="card-text">
                                            Eres dueño y trabajador a la vez. 
                                            Gestiona tu propia agenda y servicios de manera independiente.
                                        </p>
                                        <div class="form-check d-flex justify-content-center">
                                            <input class="form-check-input" type="radio" 
                                                   name="TipoPerfil" id="tipoIndependiente" 
                                                   value="TrabajadorIndependiente">
                                            <label class="form-check-label ms-2" for="tipoIndependiente">
                                                Seleccionar esta opción
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-info-circle"></i> 
                            Al seleccionar una opción, podrás crear tu perfil público y comenzar a gestionar 
                            tu negocio en BeautyFlow Manager.
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                Continuar con la Creación del Perfil
                            </button>
                        </div>
                    </form>

                    <hr class="my-4" />

                    <div class="text-center">
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Volver al Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
