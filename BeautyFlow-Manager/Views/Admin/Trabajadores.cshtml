@model IEnumerable<BeautyFlow_Manager.Models.TrabajadorIndependiente>
@{
    ViewData["Title"] = "Gestión de Trabajadores";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="fas fa-user-tie me-2"></i>Trabajadores Independientes</h2>
        </div>
    </div>

    <!-- Filtros y Búsqueda -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-5">
                    <input type="text" name="buscar" class="form-control" placeholder="Buscar por nombre, especialidad o email..." value="@Context.Request.Query["buscar"]">
                </div>
                <div class="col-md-3">
                    <select name="especialidad" class="form-select">
                        <option value="">Todas las especialidades</option>
                        <option value="Peluquería">Peluquería</option>
                        <option value="Manicure">Manicure</option>
                        <option value="Maquillaje">Maquillaje</option>
                        <option value="Barbería">Barbería</option>
                        <option value="Estética">Estética</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="fas fa-search me-1"></i>Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Grid de Trabajadores -->
    <div class="row">
        @foreach (var trabajador in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        @if (!string.IsNullOrEmpty(trabajador.FotoUrl))
                        {
                            <img src="@trabajador.FotoUrl" alt="@trabajador.NombreCompleto" class="rounded-circle mb-3" width="100" height="100" style="object-fit: cover;">
                        }
                        else
                        {
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 100px; height: 100px; font-size: 2rem;">
                                @trabajador.NombreCompleto.Substring(0, 1).ToUpper()
                            </div>
                        }
                        
                        <h5 class="card-title">@trabajador.NombreCompleto</h5>
                        <p class="text-primary mb-2">
                            <i class="fas fa-cut me-1"></i>@trabajador.EspecialidadPrincipal
                        </p>
                        
                        @if (!string.IsNullOrEmpty(trabajador.OtrasEspecialidades))
                        {
                            <p class="small text-muted mb-2">@trabajador.OtrasEspecialidades</p>
                        }
                        
                        <div class="mb-3">
                            <span class="badge bg-info">@trabajador.AniosExperiencia años experiencia</span>
                            @if (trabajador.PrecioReferencial.HasValue)
                            {
                                <span class="badge bg-success">$@trabajador.PrecioReferencial.Value.ToString("F2")</span>
                            }
                        </div>
                        
                        <div class="text-start small">
                            <p class="mb-1"><i class="fas fa-envelope me-2"></i>@trabajador.EmailProfesional</p>
                            <p class="mb-1"><i class="fas fa-phone me-2"></i>@trabajador.Telefono</p>
                        </div>
                    </div>
                    <div class="card-footer bg-white">
                        <div class="d-grid gap-2">
                            <a asp-action="DetalleTrabajador" asp-route-id="@trabajador.Id" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-eye me-1"></i>Ver Perfil Completo
                            </a>
                            <a asp-action="HistorialContratos" asp-route-id="@trabajador.Id" class="btn btn-outline-secondary btn-sm">
                                <i class="fas fa-history me-1"></i>Historial Contratos
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-user-slash fa-3x text-muted mb-3"></i>
            <p class="text-muted">No se encontraron trabajadores con los filtros aplicados</p>
        </div>
    }
</div>
