@model IEnumerable<BeautyFlow_Manager.Models.Salon>
@{
    ViewData["Title"] = "Gestión de Salones";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2><i class="fas fa-store me-2"></i>Gestión de Salones</h2>
                <a asp-action="AsignarSuscripcion" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Nueva Suscripción
                </a>
            </div>
        </div>
    </div>

    <!-- Filtros y Búsqueda -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="buscar" class="form-control" placeholder="Buscar por nombre, email o NIT..." value="@Context.Request.Query["buscar"]">
                </div>
                <div class="col-md-3">
                    <select name="estado" class="form-select">
                        <option value="">Todos los estados</option>
                        <option value="Activo">Activos</option>
                        <option value="Inactivo">Inactivos</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="suscripcion" class="form-select">
                        <option value="">Todas las suscripciones</option>
                        <option value="FREE">FREE</option>
                        <option value="BASIC">BASIC</option>
                        <option value="PREMIUM">PREMIUM</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="fas fa-search me-1"></i>Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabla de Salones -->
    <div class="card">
        <div class="card-header bg-white">
            <h5 class="mb-0">Listado de Salones (@Model.Count())</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Salón</th>
                            <th>Dueño</th>
                            <th>Contacto</th>
                            <th>Suscripción</th>
                            <th>Estado</th>
                            <th>Fecha Registro</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var salon in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(salon.LogoUrl))
                                        {
                                            <img src="@salon.LogoUrl" alt="@salon.NombreSalon" class="rounded-circle me-3" width="50" height="50" style="object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                                                @salon.NombreSalon.Substring(0, 1).ToUpper()
                                            </div>
                                        }
                                        <div>
                                            <strong>@salon.NombreSalon</strong><br>
                                            <small class="text-muted">@salon.NitRuc</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@salon.Usuario?.NombreCompleto</td>
                                <td>
                                    <div><i class="fas fa-envelope me-1"></i>@salon.Email</div>
                                    <div><i class="fas fa-phone me-1"></i>@salon.Telefono</div>
                                </td>
                                <td>
                                    @{
                                        var suscripcion = salon.Suscripciones?.FirstOrDefault(s => s.Estado == BeautyFlow_Manager.Models.EstadoSuscripcion.Activa);
                                        if (suscripcion != null)
                                        {
                                            <span class="badge bg-@(suscripcion.TipoSuscripcion.Nombre == "PREMIUM" ? "warning" : suscripcion.TipoSuscripcion.Nombre == "BASIC" ? "info" : "secondary")">
                                                @suscripcion.TipoSuscripcion.Nombre
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Sin suscripción</span>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (salon.Activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td>@salon.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="DetalleSalon" asp-route-id="@salon.Id" class="btn btn-outline-info" title="Ver detalle">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="EditarSalon" asp-route-id="@salon.Id" class="btn btn-outline-primary" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="HistorialSuscripciones" asp-route-id="@salon.Id" class="btn btn-outline-warning" title="Historial">
                                            <i class="fas fa-history"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-store-slash fa-3x text-muted mb-3"></i>
                <p class="text-muted">No se encontraron salones con los filtros aplicados</p>
            </div>
        }
    </div>
</div>
