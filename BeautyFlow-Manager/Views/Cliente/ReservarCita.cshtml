@model BeautyFlow_Manager.Models.ViewModels.ReservaViewModel
@{
    ViewData["Title"] = "Reservar Cita";
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="BuscarSalones">Salones</a></li>
            <li class="breadcrumb-item">@Model.Salon.NombreSalon</li>
            <li class="breadcrumb-item active">Reservar</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Información del Salón y Servicio -->
        <div class="col-lg-4 mb-4">
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Salón</h5>
                </div>
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.Salon.LogoUrl))
                    {
                        <img src="@Model.Salon.LogoUrl" alt="@Model.Salon.NombreSalon" class="rounded-circle mb-3" width="100" height="100" style="object-fit: cover;">
                    }
                    else
                    {
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 100px; height: 100px; font-size: 2rem;">
                            @Model.Salon.NombreSalon.Substring(0, 1).ToUpper()
                        </div>
                    }
                    <h6>@Model.Salon.NombreSalon</h6>
                    <p class="text-muted small mb-0">
                        <i class="fas fa-map-marker-alt me-1"></i>@Model.Salon.Direccion
                    </p>
                </div>
            </div>

            @if (Model.Servicio != null)
            {
                <div class="card">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Servicio Seleccionado</h5>
                    </div>
                    <div class="card-body">
                        <h6>@Model.Servicio.Nombre</h6>
                        <p class="text-muted small">@Model.Servicio.Descripcion</p>
                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="fas fa-clock me-1"></i>Duración:</span>
                            <strong>@Model.Servicio.DuracionMinutos min</strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span><i class="fas fa-tag me-1"></i>Costo:</span>
                            <strong class="text-success">$@Model.Servicio.Costo.ToString("F2")</strong>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Formulario de Reserva -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header bg-white">
                    <h4 class="mb-0"><i class="fas fa-calendar-check me-2"></i>Completar Reserva</h4>
                </div>
                <div class="card-body">
                    <form asp-action="CrearReserva" method="post">
                        <input type="hidden" asp-for="ServicioId" />
                        <input type="hidden" asp-for="SalonId" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Selección de Trabajador -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">1. Elige tu profesional</label>
                            <div class="row">
                                @if (Model.TrabajadoresDisponibles != null && Model.TrabajadoresDisponibles.Any())
                                {
                                    @foreach (var trabajador in Model.TrabajadoresDisponibles)
                                    {
                                        <div class="col-md-6 mb-3">
                                            <div class="form-check border rounded p-3 h-100">
                                                <input type="radio" name="TrabajadorId" value="@trabajador.TrabajadorId" class="form-check-input" id="trab_@trabajador.TrabajadorId" required />
                                                <label class="form-check-label w-100" for="trab_@trabajador.TrabajadorId">
                                                    <div class="d-flex align-items-center">
                                                        @if (!string.IsNullOrEmpty(trabajador.FotoUrl))
                                                        {
                                                            <img src="@trabajador.FotoUrl" alt="@trabajador.Nombre" class="rounded-circle me-3" width="50" height="50" style="object-fit: cover;">
                                                        }
                                                        else
                                                        {
                                                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                                                                @trabajador.Nombre.Substring(0, 1).ToUpper()
                                                            </div>
                                                        }
                                                        <div>
                                                            <strong>@trabajador.Nombre</strong>
                                                            <br><small class="text-muted">@trabajador.Especialidad</small>
                                                            @if (trabajador.AniosExperiencia.HasValue)
                                                            {
                                                                <br><small class="text-info">@trabajador.AniosExperiencia años experiencia</small>
                                                            }
                                                        </div>
                                                    </div>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="col-12">
                                        <div class="alert alert-warning">
                                            <i class="fas fa-exclamation-triangle me-2"></i>
                                            No hay trabajadores disponibles para este servicio.
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Selección de Fecha y Hora -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">2. Elige fecha y hora</label>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Fecha</label>
                                    <input type="date" name="Fecha" class="form-control" min="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Hora disponible</label>
                                    <select name="Hora" class="form-select" required>
                                        <option value="">Seleccionar hora...</option>
                                        @for (int hora = 9; hora <= 19; hora++)
                                        {
                                            <option value="@hora.ToString("D2"):00">@hora.ToString("D2"):00</option>
                                            <option value="@hora.ToString("D2"):30">@hora.ToString("D2"):30</option>
                                        }
                                    </select>
                                    <small class="form-text text-muted">Horario: 9:00 AM - 7:30 PM</small>
                                </div>
                            </div>
                            
                            <!-- Calendario de disponibilidad (se llena con AJAX) -->
                            <div id="disponibilidadContainer" class="mt-3"></div>
                        </div>

                        <!-- Notas Adicionales -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">3. Información adicional</label>
                            <textarea name="NotasCliente" class="form-control" rows="3" placeholder="¿Alguna indicación especial para tu cita?"></textarea>
                        </div>

                        <!-- Resumen y Confirmación -->
                        <div class="bg-light rounded p-3 mb-4">
                            <h6 class="fw-bold">Resumen de tu reserva</h6>
                            <ul class="list-unstyled mb-0">
                                <li><i class="fas fa-store me-2"></i><span id="resumenSalon">@Model.Salon.NombreSalon</span></li>
                                <li><i class="fas fa-concierge-bell me-2"></i><span id="resumenServicio">@Model.Servicio?.Nombre</span></li>
                                <li><i class="fas fa-user me-2"></i><span id="resumenTrabajador">Por seleccionar</span></li>
                                <li><i class="fas fa-clock me-2"></i><span id="resumenFecha">Por seleccionar</span></li>
                                <li><i class="fas fa-dollar-sign me-2"></i><strong id="resumenCosto">$@Model.Servicio?.Costo.ToString("F2")</strong></li>
                            </ul>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-check-circle me-2"></i>Confirmar Reserva
                            </button>
                            <a asp-action="VerSalon" asp-route-id="@Model.Salon.Id" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i>Volver
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function() {
        // Actualizar resumen cuando se selecciona trabajador
        $('input[name="TrabajadorId"]').change(function() {
            const nombre = $(this).next('label').find('strong').text();
            $('#resumenTrabajador').text(nombre);
        });

        // Actualizar resumen cuando se selecciona fecha/hora
        $('input[name="Fecha"], select[name="Hora"]').change(function() {
            const fecha = $('input[name="Fecha"]').val();
            const hora = $('select[name="Hora"]').val();
            if (fecha && hora) {
                const fechaObj = new Date(fecha + 'T' + hora);
                $('#resumenFecha').text(fechaObj.toLocaleDateString() + ' ' + fechaObj.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}));
            }
        });
    });
</script>
}
