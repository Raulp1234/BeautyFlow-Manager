@model IEnumerable<BeautyFlow_Manager.Models.Reserva>
@{
    ViewData["Title"] = "Reservas";
    ViewData["ActivePage"] = "Reservas";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2><i class="bi bi-calendar-check me-2"></i>Gestión de Reservas</h2>
                <a asp-action="Dashboard" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Volver al Dashboard
                </a>
            </div>
        </div>
    </div>

    <!-- Resumen -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <h3>@Model.Count()</h3>
                    <small>Total Reservas</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h3>@Model.Count(r => r.Estado == BeautyFlow_Manager.Models.EstadoReserva.Confirmada)</h3>
                    <small>Confirmadas</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center">
                    <h3>@Model.Count(r => r.Estado == BeautyFlow_Manager.Models.EstadoReserva.Pendiente)</h3>
                    <small>Pendientes</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h3>@Model.Count(r => r.Estado == BeautyFlow_Manager.Models.EstadoReserva.Cancelada)</h3>
                    <small>Canceladas</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Reservas -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-list-task me-2"></i>Listado de Reservas</h5>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Cliente</th>
                                        <th>Servicio</th>
                                        <th>Trabajador</th>
                                        <th>Fecha y Hora</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var reserva in Model)
                                    {
                                        <tr>
                                            <td>@reserva.Cliente?.NombreCompleto</td>
                                            <td>@reserva.Servicio?.Nombre</td>
                                            <td>@reserva.Trabajador?.NombreCompleto</td>
                                            <td>@reserva.FechaHoraInicio.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                <span class="badge bg-@(reserva.Estado switch
                                                {
                                                    BeautyFlow_Manager.Models.EstadoReserva.Confirmada => "success",
                                                    BeautyFlow_Manager.Models.EstadoReserva.Pendiente => "warning",
                                                    BeautyFlow_Manager.Models.EstadoReserva.Cancelada => "danger",
                                                    _ => "secondary"
                                                })">
                                                    @reserva.Estado
                                                </span>
                                            </td>
                                            <td>
                                                @if (reserva.Estado == BeautyFlow_Manager.Models.EstadoReserva.Pendiente)
                                                {
                                                    <form asp-action="ConfirmarReserva" asp-route-id="@reserva.Id" method="post" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-success">
                                                            <i class="bi bi-check-circle"></i> Confirmar
                                                        </button>
                                                    </form>
                                                    <form asp-action="CancelarReserva" asp-route-id="@reserva.Id" method="post" class="d-inline" 
                                                          onsubmit="return confirm('¿Está seguro de cancelar esta reserva?');">
                                                        <button type="submit" class="btn btn-sm btn-danger">
                                                            <i class="bi bi-x-circle"></i> Cancelar
                                                        </button>
                                                    </form>
                                                }
                                                else if (reserva.Estado == BeautyFlow_Manager.Models.EstadoReserva.Confirmada)
                                                {
                                                    <form asp-action="CancelarReserva" asp-route-id="@reserva.Id" method="post" class="d-inline"
                                                          onsubmit="return confirm('¿Está seguro de cancelar esta reserva confirmada?');">
                                                        <button type="submit" class="btn btn-sm btn-danger">
                                                            <i class="bi bi-x-circle"></i> Cancelar
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <i class="bi bi-info-circle me-2"></i>No hay reservas registradas para este salón.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
