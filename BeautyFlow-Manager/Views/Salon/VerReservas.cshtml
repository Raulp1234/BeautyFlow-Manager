@model IEnumerable<BeautyFlow_Manager.Models.Reserva>
@{
    ViewData["Title"] = "Reservas del Servicio";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="fas fa-calendar-alt me-2"></i>Reservas - @ViewBag.ServicioNombre</h4>
                    <a asp-action="Servicios" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-arrow-left me-1"></i>Volver a Servicios
                    </a>
                </div>
                <div class="card-body p-0">
                    <!-- Resumen -->
                    <div class="row g-3 p-3 bg-light border-bottom">
                        <div class="col-md-3">
                            <div class="text-center">
                                <h3 class="text-primary">@Model.Count()</h3>
                                <small class="text-muted">Total Reservas</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h3 class="text-success">@Model.Count(r => r.Estado == EstadoReserva.Confirmada)</h3>
                                <small class="text-muted">Confirmadas</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h3 class="text-warning">@Model.Count(r => r.Estado == EstadoReserva.Pendiente)</h3>
                                <small class="text-muted">Pendientes</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h3 class="text-danger">@Model.Count(r => r.Estado == EstadoReserva.Cancelada)</h3>
                                <small class="text-muted">Canceladas</small>
                            </div>
                        </div>
                    </div>

                    <!-- Tabla de reservas -->
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th>Cliente</th>
                                    <th>Fecha y Hora</th>
                                    <th>Trabajador</th>
                                    <th>Estado</th>
                                    <th>Fecha Reserva</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var reserva in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div>
                                                    <strong>@reserva.Cliente?.NombreCompleto</strong>
                                                    <br><small class="text-muted">@reserva.Cliente?.Email</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div>
                                                <strong>@reserva.FechaHoraInicio.ToString("dd/MM/yyyy")</strong>
                                                <br><small class="text-muted">@reserva.FechaHoraInicio.ToString("HH:mm") - @reserva.FechaHoraFin.ToString("HH:mm")</small>
                                            </div>
                                        </td>
                                        <td>
                                            @if (reserva.Trabajador != null)
                                            {
                                                <span>@reserva.Trabajador.NombreCompleto</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (reserva.Estado == EstadoReserva.Confirmada)
                                            {
                                                <span class="badge bg-success">Confirmada</span>
                                            }
                                            else if (reserva.Estado == EstadoReserva.Pendiente)
                                            {
                                                <span class="badge bg-warning text-dark">Pendiente</span>
                                            }
                                            else if (reserva.Estado == EstadoReserva.Cancelada)
                                            {
                                                <span class="badge bg-danger">Cancelada</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@reserva.Estado</span>
                                            }
                                        </td>
                                        <td>
                                            <small class="text-muted">@reserva.FechaReserva.ToString("dd/MM/yyyy HH:mm")</small>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                @if (reserva.Estado == EstadoReserva.Pendiente)
                                                {
                                                    <form asp-action="ConfirmarReserva" asp-route-id="@reserva.Id" method="post" style="display:inline;">
                                                        <button type="submit" class="btn btn-outline-success" title="Confirmar">
                                                            <i class="fas fa-check"></i>
                                                        </button>
                                                    </form>
                                                    <form asp-action="CancelarReserva" asp-route-id="@reserva.Id" method="post" style="display:inline;" onsubmit="return confirm('¿Estás seguro de cancelar esta reserva?');">
                                                        <button type="submit" class="btn btn-outline-danger" title="Cancelar">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    </form>
                                                }
                                                else if (reserva.Estado == EstadoReserva.Confirmada)
                                                {
                                                    <form asp-action="CancelarReserva" asp-route-id="@reserva.Id" method="post" style="display:inline;" onsubmit="return confirm('¿Estás seguro de cancelar esta reserva confirmada?');">
                                                        <button type="submit" class="btn btn-outline-danger" title="Cancelar">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    </form>
                                                }
                                                <button type="button" class="btn btn-outline-info" title="Ver detalles" data-bs-toggle="modal" data-bs-target="#modalDetalle_@reserva.Id">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>

                                    <!-- Modal Detalle -->
                                    <div class="modal fade" id="modalDetalle_@reserva.Id" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Detalle de Reserva</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <p><strong>Cliente:</strong> @reserva.Cliente?.NombreCompleto</p>
                                                    <p><strong>Email:</strong> @reserva.Cliente?.Email</p>
                                                    <p><strong>Servicio:</strong> @reserva.Servicio?.Nombre</p>
                                                    <p><strong>Fecha:</strong> @reserva.FechaHoraInicio.ToString("dd/MM/yyyy")</p>
                                                    <p><strong>Hora:</strong> @reserva.FechaHoraInicio.ToString("HH:mm") - @reserva.FechaHoraFin.ToString("HH:mm")</p>
                                                    <p><strong>Trabajador:</strong> @(reserva.Trabajador?.NombreCompleto ?? "No asignado")</p>
                                                    <p><strong>Estado:</strong> @reserva.Estado</p>
                                                    <p><strong>Fecha de Reserva:</strong> @reserva.FechaReserva.ToString("dd/MM/yyyy HH:mm")</p>
                                                    @if (!string.IsNullOrEmpty(reserva.Nota))
                                                    {
                                                        <p><strong>Nota:</strong> @reserva.Nota</p>
                                                    }
                                                    @if (reserva.Estado == EstadoReserva.Cancelada && !string.IsNullOrEmpty(reserva.MotivoCancelacion))
                                                    {
                                                        <p><strong>Motivo Cancelación:</strong> @reserva.MotivoCancelacion</p>
                                                    }
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No hay reservas para este servicio aún</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Inicializar modales de Bootstrap
    document.querySelectorAll('.modal').forEach(modal => {
        modal.addEventListener('show.bs.modal', function () {
            // Cerrar otros modales abiertos
            document.querySelectorAll('.modal.show').forEach(openModal => {
                if (openModal !== this) {
                    const bsModal = bootstrap.Modal.getInstance(openModal);
                    if (bsModal) bsModal.hide();
                }
            });
        });
    });
</script>
}
