@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0 text-center">@ViewData["Title"]</h3>
                </div>
                <div class="card-body text-center">
                    <i class="bi bi-lock-fill text-danger" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">No tienes permisos para acceder a esta página</h4>
                    <p class="text-muted">Contacta al administrador si crees que esto es un error.</p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">Volver al Inicio</a>
                </div>
            </div>
        </div>
    </div>
</div>
