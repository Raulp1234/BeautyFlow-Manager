@{
    ViewData["Title"] = "Cuenta Bloqueada";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-warning">
                <div class="card-header bg-warning text-dark">
                    <h3 class="mb-0 text-center">@ViewData["Title"]</h3>
                </div>
                <div class="card-body text-center">
                    <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">Tu cuenta ha sido bloqueada temporalmente</h4>
                    <p class="text-muted">Demasiados intentos fallidos. Por favor, intenta más tarde o contacta al administrador.</p>
                    <a asp-action="Login" class="btn btn-primary mt-3">Volver al Login</a>
                </div>
            </div>
        </div>
    </div>
</div>
